{
  "schemaVersion": "0.1.0",
  "id": "general-unsorted-clip",
  "name": "General — Unsorted",
  "behavior": "create",
  "noteContentFormat": "# {{title}}\n\n> [!info] Source\n> **URL:** {{url}}\n> **Clipped:** {{date:YYYY-MM-DD}}\n> **Author:** {{author}}\n\n## Summary\n\n{{description}}\n\n---\n\n{{content}}\n\n---\n\n## Highlights\n\n{{highlights}}",
  "properties": [
    { "name": "type",    "value": "web-clip",           "type": "text" },
    { "name": "module",  "value": "UNKNOWN",            "type": "text" },
    { "name": "topic",   "value": "unsorted",           "type": "text" },
    { "name": "source",  "value": "{{url}}",            "type": "text" },
    { "name": "author",  "value": "{{author}}",         "type": "text" },
    { "name": "clipped", "value": "{{date:YYYY-MM-DD}}","type": "date"  },
    { "name": "tags",    "value": "web-clip, unprocessed", "type": "text" }
  ],
  "triggers": [],
  "vault": "Claude Uni Brain",
  "outputPathFormat": "_web-clips/unsorted/{{date:YYYY-MM-DD}} - {{title}}"
}
